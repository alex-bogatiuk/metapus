# Metapus Single-Tenant Deployment Configuration
# Copy this file to .env and fill in the values.

# --- Required ---
# Generate a strong random secret for JWT tokens:
#   openssl rand -base64 32
JWT_SECRET=change-me-to-a-strong-random-secret

# Tenant ID — filled after running:
#   docker compose run --rm init create --slug default --name "My Company"
TENANT_ID=

# --- Optional ---
POSTGRES_PASSWORD=metapus
LOG_LEVEL=info

# Version reported by the server (set to match your source/release tag)
METAPUS_VERSION=v1.0.0

# Updater Agent — pulls new Docker images from registry
UPDATER_TAG=latest
# REGISTRY_TOKEN=ghp_...  # GitHub token for private registry (if needed)

# Port mapping (host:container)
# APP_PORT=8080
# FRONTEND_PORT=3000
# POSTGRES_PORT=5432
# UPDATER_PORT=9090
